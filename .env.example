# ─────────────────────────────────────────────────────────────
# App
# ─────────────────────────────────────────────────────────────
APP_NAME="SvelteKit Template"
ORIGIN="http://localhost:5173"
# Extra comma-separated origins allowed to start auth flows (optional).
TRUSTED_ORIGINS=""

# ─────────────────────────────────────────────────────────────
# Database — Drizzle + MariaDB/MySQL (mysql2)
# Replace with your DB credentials!
# ─────────────────────────────────────────────────────────────
DATABASE_URL="mysql://user:password@host:3306/db-name"

# ─────────────────────────────────────────────────────────────
# Better Auth
# For production use 32+ chars generated with high entropy:
#   npx @better-auth/cli secret
# ─────────────────────────────────────────────────────────────
BETTER_AUTH_SECRET=""

# Comma-separated user ids that are always admins (optional).
ADMIN_USER_IDS=""

# ─────────────────────────────────────────────────────────────
# Email — EMAIL_PROVIDER: resend | smtp | console (default)
# Magic links, email verification and password resets use this.
# ─────────────────────────────────────────────────────────────
EMAIL_PROVIDER="console"
EMAIL_FROM="SvelteKit Template <onboarding@example.com>"
# Resend (https://resend.com)
RESEND_API_KEY=""
# SMTP (any provider)
SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""

# OAuth — Google (https://console.cloud.google.com/apis/credentials)
# Redirect URI: {ORIGIN}/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# OAuth — Microsoft / Entra ID (https://portal.azure.com)
# Redirect URI: {ORIGIN}/api/auth/callback/microsoft
MICROSOFT_CLIENT_ID=""
MICROSOFT_CLIENT_SECRET=""
MICROSOFT_TENANT_ID="common"

# ─────────────────────────────────────────────────────────────
# AI providers (each is optional; configure the ones you use)
# AI_DEFAULT_PROVIDER: openai | gemini | deepseek | anthropic
# ─────────────────────────────────────────────────────────────
AI_DEFAULT_PROVIDER="openai"

OPENAI_API_KEY=""
OPENAI_MODEL="gpt-5.5"

DEEPSEEK_API_KEY=""
DEEPSEEK_MODEL="deepseek-4.1"

GEMINI_API_KEY=""
GEMINI_MODEL="gemini-3.5-flash"

ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-opus-4-8"

# ─────────────────────────────────────────────────────────────
# Cloudflare Turnstile (https://dash.cloudflare.com/?to=/:account/turnstile)
# Leave empty to disable captcha during local development.
# ─────────────────────────────────────────────────────────────
PUBLIC_TURNSTILE_SITE_KEY=""
TURNSTILE_SECRET_KEY=""
